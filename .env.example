MTOKEN="xxxxxxxxxxxxxxxxxxxx"
MHASH="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CHASH="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
